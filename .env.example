# ─── Copy to .env and fill in your keys ───────────────────────

# Anthropic (required — used for AI synthesis)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ElevenLabs (required for Friday voice)
# Get key at: https://elevenlabs.io
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here
# Default "Rachel" voice. Replace with your own cloned voice ID for a custom Friday voice.
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM

# OpenAI TTS (optional fallback if ElevenLabs is unavailable)
OPENAI_API_KEY=

# News API (optional but recommended — without it Friday uses RSS feeds)
# Get key at: https://newsapi.org
NEWS_API_KEY=your_newsapi_key_here

# ─── App settings ──────────────────────────────────────────────
FRIDAY_LOG_LEVEL=INFO
FRIDAY_CACHE_TTL=300

# Server (leave as-is for local use)
API_HOST=127.0.0.1
API_PORT=8000
